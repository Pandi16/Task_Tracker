<header class="topbar">
  <div>
    <a class="brand" href="/">NX Services Tracker</a>
  </div>
  <nav>
    <a href="/">Dashboard</a>
    <a href="/items">Items</a>
    <a href="/waiting">Waiting For</a>
    <a href="/items/new">Create Item</a>
    <a href="/profile">My Password</a>
    <% if (currentUser && currentUser.role === 'admin') { %><a href="/users">Users</a><% } %>
  </nav>
