<!DOCTYPE html>
<html>
<head>
  <title>Users - NX Services Tracker</title>
  <link rel="stylesheet" href="/public/styles.css">
</head>
<body>
  <%- include('partials-header') %>
  <main class="container">
    <section class="hero"><div><h1>Users</h1><p>Add, update, deactivate, or reactivate tracker users.</p></div></section>
    <section class="two-column">
      <div class="panel">
        <h2>Add User</h2>
        <% if (error) { %><div class="alert"><%= error %></div><% } %>
        <form method="POST" action="/users" class="stack-form">
          <label>Name<input name="name" required></label>
          <label>Email<input name="email" type="email" required></label>
          <label>Role<select name="role"><% roles.forEach(role => { %><option><%= role %></option><% }) %></select></label>
          <label>Password<input name="password" type="password" required></label>
          <button class="primary-button">Add User</button>
        </form>
      </div>
      <div class="panel">
        <h2>Existing Users</h2>
        <p class="muted">Delete is handled as deactivate so old item history is preserved.</p>
        <table>
          <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody>
            <% users.forEach(user => { %>
              <tr class="<%= user.is_active ? '' : 'inactive-row' %>">
                <td colspan="5">
                  <form method="POST" action="/users/<%= user.id %>/update" class="inline-user-form">
                    <input name="name" required value="<%= user.name %>">
                    <input name="email" type="email" required value="<%= user.email %>">
                    <select name="role"><% roles.forEach(role => { %><option <%= user.role === role ? 'selected' : '' %>><%= role %></option><% }) %></select>
                    <span class="badge <%= user.is_active ? '' : 'danger-badge' %>"><%= user.is_active ? 'Active' : 'Inactive' %></span>
                    <div class="user-actions">
                      <input name="password" type="password" placeholder="New password optional">
                      <button type="submit">Update</button>
                    </div>
                  </form>
                  <div class="row-actions">
                    <% if (user.is_active) { %>
                      <form method="POST" action="/users/<%= user.id %>/deactivate" onsubmit="return confirm('Deactivate <%= user.name %>? They will not be able to log in.');">
                        <button class="danger-button" type="submit">Deactivate</button>
                      </form>
                    <% } else { %>
                      <form method="POST" action="/users/<%= user.id %>/activate">
                        <button class="primary-button compact" type="submit">Reactivate</button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</body>
</html>
