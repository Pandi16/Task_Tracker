<!DOCTYPE html>
<html>
<head>
  <title>Users - NX Services Tracker</title>
  <link rel="stylesheet" href="/public/styles.css">
</head>
<body>
  <%- include('partials-header') %>
  <main class="container">
    <section class="hero"><div><h1>Users</h1><p>Add, update, delete, reset tracker users, and link Telegram chat IDs.</p></div></section>
    <section class="two-column">
      <div class="panel">
        <h2>Add User</h2>
        <% if (error) { %><div class="alert"><%= error %></div><% } %>
        <% if (success) { %><div class="success"><%= success %></div><% } %>
        <form method="POST" action="/users" class="stack-form">
          <label>Name<input name="name" required></label>
          <label>Email<input name="email" type="email" required></label>
          <label>Role<select name="role"><% roles.forEach(role => { %><option><%= role %></option><% }) %></select></label>
          <label>Telegram Chat ID <span class="muted">optional, get it by sending /id to the bot</span><input name="telegram_chat_id" placeholder="Example: 123456789"></label>
          <label class="checkbox-label"><input name="telegram_opt_in" type="checkbox" value="1"> Enable Telegram reminders and commands</label>
          <label>Password<input name="password" type="password" required minlength="8"></label>
          <button class="primary-button">Add User</button>
        </form>
      </div>
      <div class="panel users-panel">
        <h2>Existing Users</h2>
        <p class="muted">Delete removes login access. Old item ownership is cleared and old comments show as “Deleted user”. Password reset for another user is allowed only from <strong><%= superAdminEmail %></strong>.</p>
        <table>
          <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody>
            <% users.forEach(user => { %>
              <tr>
                <td colspan="5">
                  <form method="POST" action="/users/<%= user.id %>/update" class="inline-user-form">
                    <input name="name" required value="<%= user.name %>">
                    <input name="email" type="email" required value="<%= user.email %>">
                    <select name="role"><% roles.forEach(role => { %><option <%= user.role === role ? 'selected' : '' %>><%= role %></option><% }) %></select>
                    <input name="telegram_chat_id" placeholder="Telegram chat ID" value="<%= user.telegram_chat_id || '' %>">
                    <label class="mini-checkbox"><input name="telegram_opt_in" type="checkbox" value="1" <%= user.telegram_opt_in ? 'checked' : '' %>> TG</label>
                    <span class="badge"><%= user.is_active ? 'Active' : 'Inactive' %></span>
                    <button type="submit">Update</button>
                  </form>

                  <div class="row-actions user-row-extra">
                    <% if (currentUser && currentUser.email === superAdminEmail) { %>
                      <form method="POST" action="/users/<%= user.id %>/password" class="password-reset-form">
                        <input name="password" type="password" placeholder="New password" minlength="8" required>
                        <button type="submit">Change Password</button>
                      </form>
                    <% } %>

                    <% if (currentUser && currentUser.id !== user.id && user.email !== superAdminEmail) { %>
                      <form method="POST" action="/users/<%= user.id %>/delete" onsubmit="return confirm('Delete <%= user.name %>? Old items will remain, but ownership/waiting-for references to this user will be cleared.');">
                        <button class="danger-button" type="submit">Delete</button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</body>
</html>
