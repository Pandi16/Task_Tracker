SESSION_SECRET=nx-tracker-local-secret-change-later
DATABASE_URL=postgres://nxuser:NxStrongPassword123@127.0.0.1:5432/nxtracker
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Google Apps Script mailer over HTTPS. No SMTP port is required.
APPS_SCRIPT_WEBAPP_URL=
APPS_SCRIPT_SECRET=
MAIL_FROM_NAME=NX Tracker

# Daily reminder time uses this timezone, not the Windows VM local time.
# Use Asia/Kolkata for 10:00 AM IST. Time is in 24-hour format.
DAILY_REMINDER_TIMEZONE=Asia/Kolkata
DAILY_REMINDER_HOUR=10
DAILY_REMINDER_MINUTE=0

# Dashboard recently updated section limit.
RECENT_ITEMS_LIMIT=10
