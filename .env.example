SESSION_SECRET=nx-tracker-local-secret-change-later
DATABASE_URL=postgres://nxuser:NxStrongPassword123@127.0.0.1:5432/nxtracker
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Google Apps Script mailer over HTTPS. No SMTP port is required.
APPS_SCRIPT_WEBAPP_URL=
APPS_SCRIPT_SECRET=
MAIL_FROM_NAME=NX Tracker

# Daily reminder time uses this timezone, not the Windows VM local time.
# Use Asia/Kolkata for 10:00 AM IST. Time is in 24-hour format.
DAILY_REMINDER_TIMEZONE=Asia/Kolkata
DAILY_REMINDER_HOUR=10
DAILY_REMINDER_MINUTE=0

# Dashboard recently updated section limit.
RECENT_ITEMS_LIMIT=10


# Public URL used in emails, Telegram reminders, and OpenClaw responses.
TRACKER_BASE_URL=http://ustr-mvm-8134.na.uis.unisys.com:3000

# API key required by OpenClaw/MCP automation endpoints.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TRACKER_API_KEY=

# Telegram bot integration
# Create a bot using @BotFather and paste the token here.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
# Set true only after adding telegram_chat_id values in Users page.
TELEGRAM_BOT_POLLING_ENABLED=false
TELEGRAM_POLL_INTERVAL_SECONDS=20
